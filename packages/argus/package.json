{
	"name": "@vforsh/argus",
	"version": "0.1.17",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vforsh/argus.git",
		"directory": "packages/argus"
	},
	"type": "module",
	"bin": {
		"argus": "dist/argus.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"schemas"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@vforsh/argus-core": "workspace:*",
		"@vforsh/argus-plugin-api": "workspace:*",
		"@vforsh/argus-watcher": "workspace:*",
		"commander": "14.0.2",
		"esbuild": "0.25.12",
		"prettier": "3.7.4"
	},
	"scripts": {
		"clean": "node ../../scripts/clean-dist.mjs",
		"build": "npm run clean && tsc -b && bun run bundle",
		"bundle": "bun build dist/bin.js --outfile dist/argus.js --target node --external esbuild",
		"typecheck": "tsc -b --pretty false",
		"chrome:start": "bun src/bin.ts chrome start"
	}
}
